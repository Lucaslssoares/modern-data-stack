# =============================================================================
# Variáveis de ambiente — copie para config/.env e preencha com valores reais.
# NUNCA versione config/.env com credenciais reais.
# =============================================================================

# --- Airflow ---
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API__SECRET_KEY=gere_uma_chave_segura_aqui

# --- API ---
API_KEY=coloque_sua_chave_aqui

# --- PostgreSQL ---
DB_HOST=postgres        # nome do serviço Docker; use localhost para rodar local
DB_PORT=5432
DB_USER=airflow
DB_PASSWORD=airflow
DB_NAME=airflow

# --- Opcional ---
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
